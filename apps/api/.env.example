ORBIT_APP_NAME=Orbit
ORBIT_DEPLOYMENT_MODE=selfhosted
ORBIT_CONFIG_MODE=memory
ORBIT_API_PORT=3001
ORBIT_API_URL=http://localhost:3001
ORBIT_WEB_URL=http://localhost:3000
# Set this to .example.com when web/api use subdomains like app.example.com + api.example.com
ORBIT_COOKIE_DOMAIN=
# Optional in Docker: auto-generated and persisted in /var/lib/orbit when omitted.
# ORBIT_INTERNAL_JWT_SECRET=
# Optional in Docker: auto-generated and persisted in /var/lib/orbit when omitted.
# BETTER_AUTH_SECRET=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orbit
DATABASE_SSL=false
# Optional: defaults to the hostname from ORBIT_WEB_URL.
# PASSKEY_RP_ID=
# Optional: defaults to ORBIT_APP_NAME.
# PASSKEY_RP_NAME=
# Optional: defaults to ORBIT_WEB_URL.
# PASSKEY_ORIGIN=

# Vercel Edge Config mode only
# ORBIT_CONFIG_MODE=edge
# ORBIT_VERCEL_EDGE_CONFIG=
# ORBIT_VERCEL_EDGE_CONFIG_STORE_ID=
# ORBIT_VERCEL_API_TOKEN=
# ORBIT_VERCEL_EDGE_CONFIG_ITEM_KEY=instance-config

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
CFX_CLIENT_ID=
CFX_CLIENT_SECRET=
CFX_DISCOVERY_URL=
CFX_ISSUER=
CFX_AUTHORIZATION_URL=
CFX_TOKEN_URL=
CFX_USERINFO_URL=
CFX_SCOPES=openid,profile,email
