# Required
POSTGRES_PASSWORD=change-me
ORBIT_PUBLIC_WEB_URL=https://app.example.com
ORBIT_PUBLIC_API_URL=https://api.example.com

# Optional image overrides
# ORBIT_API_IMAGE=ghcr.io/projectkura/orbit-api:latest
# ORBIT_WEB_IMAGE=ghcr.io/projectkura/orbit-web:latest

# Usually needed when using app.example.com + api.example.com
ORBIT_COOKIE_DOMAIN=.example.com

# Optional
ORBIT_APP_NAME=Orbit

# Optional OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
CFX_CLIENT_ID=
CFX_CLIENT_SECRET=
CFX_DISCOVERY_URL=
CFX_ISSUER=
CFX_AUTHORIZATION_URL=
CFX_TOKEN_URL=
CFX_USERINFO_URL=
CFX_SCOPES=openid,profile,email
